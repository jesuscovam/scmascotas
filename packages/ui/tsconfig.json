{
  "extends": ["@scmascotas/typescript-config/svelte.json"],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "allowArbitraryExtensions": true,
    "strictNullChecks": true,
    "types": ["svelte"]
  },
  "include": ["dist", "./src/**/*.svelte", "./src/**/*.ts"],
  "exclude": ["node_modules", ".svelte-kit"]
}
