{
  "name": "@scmascotas/ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch --input=src",
    "build": "svelte-kit sync && svelte-package --input=src",
    "lint": "eslint .",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.16.0",
    "@scmascotas/eslint-config": "workspace:*",
    "@scmascotas/typescript-config": "workspace:*",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^24.12.0",
    "@vitest/browser-playwright": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.1.0"
  },
  "dependencies": {
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  }
}
