# Neon Postgres (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=vercelblob_rw_...

# Nightly environment — overrides DATABASE_URL when set.
# Point this at the Neon `nightly` branch so the nightly Vercel
# environment uses a stable DB instead of the ephemeral PR preview DB.
# OVERRIDE_NIGHTLY_DATABASE_URL=postgresql://user:password@host/nightly?sslmode=require

# Auth (better-auth) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-byte-string
# Set to the canonical public URL of the app (no trailing slash).
# Used by better-auth to build verification email links.
# Locally: http://localhost:5173  |  Production: https://scmascotas.xyz
BETTER_AUTH_URL=http://localhost:5173

# Google OAuth (optional — Google sign-in hidden if unset)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Resend (email verification on signup + contact form + notification alerts)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Contact form — address that receives messages submitted via the contact form
CONTACT_EMAIL=you@example.com

# Notifications (Sprint 7)
# From address for alert emails. Empty → defaults to the SC Mascotas sender.
# NOTIFY_EMAIL_FROM="SC Mascotas <no-reply@emails.jesuscova.com>"
# WhatsApp push channel (cost-gated seam — OFF by default). The WhatsApp Business
# API bills per conversation and requires template approval, so this stays off
# until set to "true" AND the user opts in. No integration ships yet. See PLAN.md §15.
# NOTIFY_WHATSAPP_ENABLED=false

# Upstash Redis (rate limiting — active in production only — https://upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Replicate API token for CLIP image embeddings (Sprint 5)
# Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Stadia Maps API key for map tiles (Sprint 6)
# Free tier: 200k tile requests/month — https://client.stadiamaps.com → API Keys
# Empty value → falls back to direct OpenStreetMap tiles (rate-limited; fine for dev/forks)
PUBLIC_STADIA_MAPS_KEY=
